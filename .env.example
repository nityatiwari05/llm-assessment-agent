# Copy to .env and fill in for local dev. In deployment, set these as real
# environment variables in your host's dashboard instead of shipping a .env file.

LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional overrides:
# CATALOG_PATH=./data/catalog.json
# RETRIEVAL_TOP_K=25
# LLM_TIMEOUT_SECONDS=22
# LLM_MAX_TOKENS=1500
